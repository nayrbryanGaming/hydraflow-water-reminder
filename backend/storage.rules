rules_version = '2';

service firebase.storage {
  match /b/{bubble}/o {
    
    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/{allPaths=**} {
      // Users can only access their own profile images and assets
      // Standard Play Store requirement for sensitive profile data
      allow read, write: if isOwner(userId);
    }
  }
}
