rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the document belongs to the requesting user
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow read, update: if isOwner(userId);
      allow delete: if false; // Users cannot delete their own profile directly

      match /hydration_logs/{logId} {
        allow read, write: if isOwner(userId);
      }

      match /reminders/{reminderId} {
        allow read, write: if isOwner(userId);
      }

      match /achievements/{achievementId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId); // Allowing client writes for MVP
      }
    }
  }
}
